# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# ── Google Sheets (optional) ──────────────────────────────────────────────────
# Leave blank to disable Google Sheets export.
# Path to your service account JSON key file downloaded from Google Cloud Console.
GOOGLE_CREDENTIALS_FILE=credentials.json
# The ID of the Google Sheet to export data into (found in the sheet URL).
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID_HERE

# ── Discord Webhook (optional) ────────────────────────────────────────────────
# Leave blank to disable webhook export.
EXPORT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run).
DATABASE_PATH=ark_breeding.db
